# ─────────────────────────────────────────────────
#  Copy to .env and fill in your credentials
#  NEVER commit .env to version control
# ─────────────────────────────────────────────────

# Kalshi RSA auth (recommended — works with Google SSO accounts)
# KALSHI_API_KEY = the key ID (UUID) from Kalshi API settings
# KALSHI_RSA_KEY_PATH = path to your .pem private key file
KALSHI_API_KEY=
KALSHI_RSA_KEY_PATH=kalshi_private_key.pem

# Alternative: email + password (not available if you use Google SSO)
# KALSHI_EMAIL=
# KALSHI_PASSWORD=

# Optional: override config.yaml settings via env
# BTC15_MAX_TRADE_USD=50
# BTC15_AUTO_TRADE=false
# BTC15_PAPER_TRADE=true
